[gd_scene format=3 uid="uid://settings_scene"]

[ext_resource type="Script" path="res://scenes/ui/settings.gd" id="1"]

[node name="Settings" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.08, 0.1, 1)

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -260.0
offset_top = -240.0
offset_right = 260.0
offset_bottom = 240.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Settings"
horizontal_alignment = 1

[node name="PresetLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
text = "Difficulty Preset"

[node name="PresetRow" type="HBoxContainer" parent="Panel/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="EasyBtn" type="Button" parent="Panel/VBox/PresetRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Easy"

[node name="NormalBtn" type="Button" parent="Panel/VBox/PresetRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Normal"

[node name="HardBtn" type="Button" parent="Panel/VBox/PresetRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Hard"

[node name="BankLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
text = "Word Bank"

[node name="BankRow" type="HBoxContainer" parent="Panel/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="CommonBtn" type="Button" parent="Panel/VBox/BankRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Common"

[node name="ExpandedBtn" type="Button" parent="Panel/VBox/BankRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Expanded"

[node name="TechnicalBtn" type="Button" parent="Panel/VBox/BankRow"]
layout_mode = 2
size_flags_horizontal = 3
toggle_mode = true
text = "Technical"

[node name="ModLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
text = "Modifiers"

[node name="ModRow" type="HBoxContainer" parent="Panel/VBox"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="CapCheck" type="CheckButton" parent="Panel/VBox/ModRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Capitalize first letter"

[node name="SentenceCheck" type="CheckButton" parent="Panel/VBox/ModRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Sentence mode"

[node name="Spacer" type="Control" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="BackBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Back"

[connection signal="pressed" from="Panel/VBox/PresetRow/EasyBtn" to="." method="_on_easy_pressed"]
[connection signal="pressed" from="Panel/VBox/PresetRow/NormalBtn" to="." method="_on_normal_pressed"]
[connection signal="pressed" from="Panel/VBox/PresetRow/HardBtn" to="." method="_on_hard_pressed"]
[connection signal="pressed" from="Panel/VBox/BankRow/CommonBtn" to="." method="_on_common_pressed"]
[connection signal="pressed" from="Panel/VBox/BankRow/ExpandedBtn" to="." method="_on_expanded_pressed"]
[connection signal="pressed" from="Panel/VBox/BankRow/TechnicalBtn" to="." method="_on_technical_pressed"]
[connection signal="toggled" from="Panel/VBox/ModRow/CapCheck" to="." method="_on_cap_toggled"]
[connection signal="toggled" from="Panel/VBox/ModRow/SentenceCheck" to="." method="_on_sentence_toggled"]
[connection signal="pressed" from="Panel/VBox/BackBtn" to="." method="_on_back_pressed"]
