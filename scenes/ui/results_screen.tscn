theme_override_font_sizes/font_size = 20
text = "Main Menu"

[connection signal="pressed" from="Center/VBox/ButtonRow/RetryBtn" to="." method="_on_retry_pressed"]
[connection signal="pressed" from="Center/VBox/ButtonRow/SettingsBtn" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="Center/VBox/ButtonRow/MainMenuBtn" to="." method="_on_main_menu_pressed"]
